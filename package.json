{
	"name": "jr-auto-motors-image-uploader-worker",
	"description": "Cloudflare Worker for uploading images to R2 and returning a public URL",
	"cloudflare": {
		"label": "Image Uploader Worker",
		"products": ["Workers"],
		"categories": [
			"starter"
		],
		"publish": true,
		"docs_url": "https://developers.cloudflare.com/workers/"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "0.11.1",
		"@eslint/js": "9.39.1",
		"@vitest/runner": "3.2.4",
		"@vitest/snapshot": "3.2.4",
		"eslint": "9.39.2",
		"globals": "16.5.0",
		"typescript": "5.9.3",
		"typescript-eslint": "8.48.0",
		"vitest": "3.2.4",
		"wrangler": "4.88.0"
	},
	"private": true,
	"scripts": {
		"build": "tsc -p tsconfig.worker.json --noEmit",
		"cf-typegen": "wrangler types",
		"check": "tsc -p tsconfig.worker.json --noEmit && wrangler deploy --dry-run",
		"deploy": "npm run build && wrangler deploy",
		"dev": "wrangler dev",
		"lint": "eslint .",
		"test": "vitest run"
	},
	"type": "module"
}
